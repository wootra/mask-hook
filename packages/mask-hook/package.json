{
  "name": "@shjeon0730/mask-hook",
  "version": "0.1.4",
  "description": "EIN/SSN masking React hook – works with React and React Native",
  "keywords": [
    "react",
    "react-native",
    "hook",
    "ssn",
    "ein",
    "mask",
    "masking",
    "input"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wootra/mask-hook"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "demo.gif"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepack": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.1.6",
    "jsdom": "^26.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.1"
  }
}
